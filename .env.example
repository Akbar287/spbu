# Environment Configuration for SPBU Blockchain Deployment
# Copy this file to .env and fill in the values

# =============================================================================
# LOCAL DEVELOPMENT (No configuration needed - Hardhat provides test accounts)
# =============================================================================

# =============================================================================
# SEPOLIA TESTNET
# =============================================================================
# Get free API key from:
# - Alchemy: https://www.alchemy.com/
# - Infura: https://infura.io/
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
REACT_APP_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# =============================================================================
# ETHEREUM MAINNET (PRODUCTION)
# =============================================================================
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# =============================================================================
# DEPLOYER WALLET
# =============================================================================
# IMPORTANT: Never commit your actual private key!
# For testnet: Create a test wallet and get Sepolia ETH from faucet
# Sepolia Faucets:
# - https://sepoliafaucet.com/
# - https://www.alchemy.com/faucets/ethereum-sepolia
DEPLOYER_PRIVATE_KEY=your_private_key_without_0x_prefix

# =============================================================================
# IPFS
# =============================================================================
# Pinata REST API example:
# REACT_APP_IPFS_API_URL=https://api.pinata.cloud/pinning/pinFileToIPFS
# REACT_APP_IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/
# REACT_APP_IPFS_API_BEARER_TOKEN=your_pinata_jwt
# Unpin URL diturunkan otomatis dari REACT_APP_IPFS_API_URL
# (contoh: .../pinning/unpin/{cid})
REACT_APP_IPFS_API_URL=
REACT_APP_IPFS_GATEWAY_URL=
REACT_APP_IPFS_API_BEARER_TOKEN=

# =============================================================================
# BLOCKCHAIN CRUD ENCRYPTION (Frontend Service Layer)
# =============================================================================
# Enabled by default in code, set explicitly for clarity
REACT_APP_BLOCKCHAIN_CRUD_ENCRYPTION_ENABLED=true
# Supported: off | aes-gcm-v1 | xor-v1
REACT_APP_BLOCKCHAIN_CRUD_ENCRYPTION_MODE=aes-gcm-v1
# IMPORTANT: set a strong secret key (min 32 chars recommended)
REACT_APP_BLOCKCHAIN_CRUD_ENCRYPTION_KEY=replace_with_strong_secret_key
# If false, encryption key is mandatory (recommended)
REACT_APP_BLOCKCHAIN_CRUD_ALLOW_FALLBACK_KEY=false
# If true, every write payload string must already be encrypted by service layer
REACT_APP_BLOCKCHAIN_CRUD_STRICT_WRITE_VALIDATION=true
# Optional hard-stop for legacy plaintext reads (turn on after migration is complete)
REACT_APP_BLOCKCHAIN_CRUD_REJECT_PLAINTEXT_READ=false

# =============================================================================
# DEPLOYED CONTRACT ADDRESSES (filled after deployment)
# =============================================================================
# These will be set after running deployment scripts
REACT_APP_ROLE_MANAGER_CONTRACT=
REACT_APP_IDENTITY_CONTRACT=
REACT_APP_ORGANIZATION_CONTRACT=
REACT_APP_ASET_MANAGEMENT_CONTRACT=
REACT_APP_ATTENDANCE_CONTRACT=
REACT_APP_FINANCE_CONTRACT=
REACT_APP_HUMAN_CAPITAL_CONTRACT=
REACT_APP_INVENTORY_CONTRACT=
REACT_APP_LOGISTIK_CONTRACT=
REACT_APP_PENGADAAN_CONTRACT=
REACT_APP_POINT_OF_SALES_CONTRACT=
REACT_APP_QUALITY_CONTROL_CONTRACT=
